# Academia Vallenata Online — Variables de entorno requeridas
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas .env al repositorio.

# ── Supabase ──────────────────────────────────────────────
# URL del proyecto Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima de Supabase (Project Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ── URL base de la app ────────────────────────────────────
# Usada para construir URLs absolutas en pagos y emails
NEXT_PUBLIC_BASE_URL=https://academiavallenataonline.com

# ── ePayco (pasarela de pagos) ────────────────────────────
# Clave pública de ePayco (dashboard.epayco.com → Integración)
NEXT_PUBLIC_EPAYCO_PUBLIC_KEY=tu-clave-publica

# ID de cliente ePayco
NEXT_PUBLIC_EPAYCO_CUSTOMER_ID=tu-customer-id

# false = modo producción real | true = modo sandbox/pruebas
NEXT_PUBLIC_EPAYCO_TEST_MODE=false
