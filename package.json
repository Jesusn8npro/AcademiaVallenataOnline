    "analyze": "ANALYZE=true next build",
    "analyze:win": "cross-env ANALYZE=true next build"
  },
  "browserslist": {
    "production": [
      "chrome >= 90",
      "firefox >= 90",
      "safari >= 14",
      "edge >= 90"
