  "scripts": {
    "dev": "node scripts/sync-samples.cjs && next dev --webpack",
    "dev:turbo": "node scripts/sync-samples.cjs && next dev",
    "sync": "node scripts/sync-samples.cjs",
    "build": "node scripts/sync-samples.cjs && next build && node scripts/inject-sw-version.mjs",
    "start": "next start",
    "preview": "next start",
    "type-check": "tsc --noEmit",
